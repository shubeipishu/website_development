# ============================================================
# 环境变量配置文件 (示例)
# 使用方式: 复制此文件为 .env 并根据需要修改
# ============================================================

# 环境类型: dev (开发) / prod (生产)
ENV_TYPE=dev

# Web 服务绑定地址与端口
# 生产默认建议使用 127.0.0.1，仅允许本机访问
# 如需公网访问，再显式改成 0.0.0.0 或指定网卡 IP
WEB_BIND_IP=127.0.0.1
WEB_PORT=3001

# 管理员 API Key (用于访问 GET /api/feedback 等敏感端点)
# 请设置一个强密钥，例如: openssl rand -hex 32
ADMIN_API_KEY=your-secret-key-here
